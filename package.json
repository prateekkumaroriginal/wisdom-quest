{
  "name": "wisdom-quest",
  "version": "0.1.3",
  "author": "Prateek",
  "description": "A desktop MCQ platformer MVP for Steam-oriented PC publishing.",
  "main": "src/electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron .\"",
    "dev:no-sandbox": "npx concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron --no-sandbox .\"",
    "build": "vite build",
    "preview": "vite --host 127.0.0.1",
    "clean:release": "node scripts/clean-release.mjs",
    "package:win": "npm run clean:release && npm run build && electron-builder --win nsis",
    "package:linux": "npm run clean:release && npm run build && electron-builder --linux AppImage deb",
    "package:mac": "npm run clean:release && npm run build && electron-builder --mac dmg zip",
    "package:all": "npm run clean:release && npm run build && electron-builder -wlm",
    "package:dir": "npm run clean:release && npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.edgecase.mcqplatformer",
    "productName": "Wisdom Quest",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource/bungee": "^5.2.7",
    "@tailwindcss/vite": "^4.2.4",
    "lucide": "^1.11.0",
    "lucide-react": "^1.14.0",
    "phaser": "^3.90.0",
    "random-words": "^2.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.1.12",
    "wait-on": "^9.0.1"
  }
}
